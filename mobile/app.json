{
  "expo": {
    "name": "자린고비",
    "slug": "jaringoby",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jaringoby",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.jaringoby.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "챌린지 지출 사진을 촬영하기 위해 카메라를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "챌린지 지출 사진을 선택하기 위해 사진 보관함을 사용합니다."
      }
    },
    "android": {
      "package": "com.jaringoby.app",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FDF6E3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "챌린지 지출 사진을 선택하기 위해 사진 보관함을 사용합니다.",
          "cameraPermission": "챌린지 지출 사진을 촬영하기 위해 카메라를 사용합니다."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FDF6E3",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#2F715D",
          "defaultChannel": "challenge-events"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
